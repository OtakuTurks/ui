{
  "name": "@otakuturks/ui",
  "version": "0.1.1",
  "description": "A Vue 3 UI component library.",
  "keywords": [
    "vue",
    "vue3",
    "js",
    "css",
    "css3",
    "ui",
    "components",
    "dark-theme",
    "design-system",
    "otakuturks"
  ],
  "author": {
    "name": "OtakuTurks",
    "url": "https://github.com/otakuturks"
  },
  "contributors": [
    {
      "name": "ewgsta",
      "url": "https://ewgsta.me"
    }
  ],
  "license": "GPL-3.0",
  "homepage": "https://otakuturks-ui.web.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/OtakuTurks/ui.git"
  },
  "bugs": {
    "url": "https://github.com/OtakuTurks/ui/issues"
  },
  "type": "module",
  "main": "./dist/otakuturks-ui.umd.cjs",
  "module": "./dist/otakuturks-ui.js",
  "exports": {
    ".": {
      "import": "./dist/otakuturks-ui.js",
      "require": "./dist/otakuturks-ui.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "storybook": "vite --mode storybook",
    "build": "vite build && vite build --mode lib",
    "build:lib": "vite build --mode lib",
    "build:storybook": "vite build --mode storybook",
    "preview": "vite preview",
    "prepare": "husky",
    "prepublishOnly": "yarn build:lib"
  },
  "dependencies": {
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "vite": "^8.0.12"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
